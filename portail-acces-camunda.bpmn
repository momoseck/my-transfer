<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_PortalAccess" targetNamespace="http://example.com/portal-access" exporter="Camunda Modeler" exporterVersion="5.18.0">
  <bpmn:process id="Process_Portal_Access" name="Portail - Accès Applications &#38; Services" isExecutable="true">
    <bpmn:startEvent id="Start_Login" name="Connexion au portail" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_Login" targetRef="Task_Authenticate" />
    <bpmn:userTask id="Task_Authenticate" name="S&#39;authentifier (Auth3S)" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Authenticate" targetRef="Task_CheckRights" />
    <bpmn:serviceTask id="Task_CheckRights" name="Vérifier droits existants" camunda:type="external" camunda:topic="portal.checkRights" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_CheckRights" targetRef="Gateway_HasAccess" />
    <bpmn:sequenceFlow id="Flow_4_yes" sourceRef="Gateway_HasAccess" targetRef="Task_OpenApp">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${hasAccess == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4_no" sourceRef="Gateway_HasAccess" targetRef="Task_SelectCatalog">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${hasAccess == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Task_OpenApp" name="Accéder à l&#39;application / Service 3s" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_OpenApp" targetRef="End_DirectAccess" />
    <bpmn:endEvent id="End_DirectAccess" name="Fin - Accès direct" />
    <bpmn:userTask id="Task_SelectCatalog" name="Ouvrir catalogue (Apps / Services)" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_SelectCatalog" targetRef="Gateway_RequestType" />
    <bpmn:exclusiveGateway id="Gateway_RequestType" name="Type de demande" />
    <bpmn:sequenceFlow id="Flow_7_app" sourceRef="Gateway_RequestType" targetRef="Task_SelectApplication">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${requestType == "APP"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_7_srv" sourceRef="Gateway_RequestType" targetRef="Task_SelectService">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${requestType == "SERVICE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Task_SelectApplication" name="Sélectionner application" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_SelectApplication" targetRef="Task_SubmitAppRequest" />
    <bpmn:userTask id="Task_SubmitAppRequest" name="Soumettre demande accès application" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_SubmitAppRequest" targetRef="Task_RegisterAppRequest" />
    <bpmn:serviceTask id="Task_RegisterAppRequest" name="Enregistrer demande (portail)" camunda:type="external" camunda:topic="portal.registerAppRequest" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_RegisterAppRequest" targetRef="Task_ManagerValidateApp" />
    <bpmn:userTask id="Task_ManagerValidateApp" name="Validation Manager (App)" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ManagerValidateApp" targetRef="Gateway_ManagerDecisionApp" />
    <bpmn:exclusiveGateway id="Gateway_ManagerDecisionApp" name="Manager OK ?" />
    <bpmn:sequenceFlow id="Flow_12_mgr_ok" sourceRef="Gateway_ManagerDecisionApp" targetRef="Task_ITValidateApp">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${managerApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_12_mgr_no" sourceRef="Gateway_ManagerDecisionApp" targetRef="Task_NotifyRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${managerApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Task_ITValidateApp" name="Validation IT (App)" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_ITValidateApp" targetRef="Gateway_ITDecisionApp" />
    <bpmn:exclusiveGateway id="Gateway_ITDecisionApp" name="IT OK ?" />
    <bpmn:sequenceFlow id="Flow_14_it_ok" sourceRef="Gateway_ITDecisionApp" targetRef="Gateway_AppType">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${itApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_14_it_no" sourceRef="Gateway_ITDecisionApp" targetRef="Task_NotifyRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${itApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_AppType" name="Type application ?">
      <bpmn:outgoing>Flow_0w8q5tp</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_15_client" sourceRef="Gateway_AppType" targetRef="Task_InstallClient">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${appType == "CLIENT_LOURD"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_InstallClient" targetRef="Task_ConfigWorkstation" />
    <bpmn:serviceTask id="Task_UpdatePortalRights" name="Mettre à jour droits portail" camunda:type="external" camunda:topic="portal.updateRights">
      <bpmn:incoming>Flow_0w8q5tp</bpmn:incoming>
      <bpmn:incoming>Flow_0q3qgef</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_UpdatePortalRights" targetRef="Task_NotifyGranted" />
    <bpmn:userTask id="Task_SelectService" name="Sélectionner service (API / interfaçage)" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Task_SelectService" targetRef="Task_SubmitServiceRequest" />
    <bpmn:userTask id="Task_SubmitServiceRequest" name="Soumettre demande accès service" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_SubmitServiceRequest" targetRef="Task_RegisterServiceRequest" />
    <bpmn:serviceTask id="Task_RegisterServiceRequest" name="Enregistrer demande (portail)" camunda:type="external" camunda:topic="portal.registerServiceRequest" />
    <bpmn:sequenceFlow id="Flow_22" sourceRef="Task_RegisterServiceRequest" targetRef="Task_ManagerValidateService" />
    <bpmn:userTask id="Task_ManagerValidateService" name="Validation Manager (Service)" />
    <bpmn:sequenceFlow id="Flow_23" sourceRef="Task_ManagerValidateService" targetRef="Gateway_ManagerDecisionService" />
    <bpmn:exclusiveGateway id="Gateway_ManagerDecisionService" name="Manager OK ?" />
    <bpmn:sequenceFlow id="Flow_24_mgr_ok" sourceRef="Gateway_ManagerDecisionService" targetRef="Task_ITValidateService">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${managerApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_24_mgr_no" sourceRef="Gateway_ManagerDecisionService" targetRef="Task_NotifyRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${managerApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Task_ITValidateService" name="Validation IT (Service)" />
    <bpmn:sequenceFlow id="Flow_25" sourceRef="Task_ITValidateService" targetRef="Gateway_ITDecisionService" />
    <bpmn:exclusiveGateway id="Gateway_ITDecisionService" name="IT OK ?" />
    <bpmn:sequenceFlow id="Flow_26_it_ok" sourceRef="Gateway_ITDecisionService" targetRef="Task_CreateContract">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${itApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_26_it_no" sourceRef="Gateway_ITDecisionService" targetRef="Task_NotifyRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${itApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Task_CreateContract" name="Créer contrat / règles d&#39;accès" camunda:type="external" camunda:topic="it.createContract" />
    <bpmn:sequenceFlow id="Flow_27" sourceRef="Task_CreateContract" targetRef="Task_ProvisionCredentials" />
    <bpmn:serviceTask id="Task_ProvisionCredentials" name="Provisionner credentials" camunda:type="external" camunda:topic="it.provisionCredentials" />
    <bpmn:sequenceFlow id="Flow_28" sourceRef="Task_ProvisionCredentials" targetRef="Task_ProvideDocs" />
    <bpmn:serviceTask id="Task_ProvideDocs" name="Fournir documentation intégration" camunda:type="external" camunda:topic="it.provideDocs" />
    <bpmn:sequenceFlow id="Flow_29" sourceRef="Task_ProvideDocs" targetRef="Task_UpdatePortalRights" />
    <bpmn:serviceTask id="Task_NotifyRejected" name="Notifier rejet" camunda:type="external" camunda:topic="portal.notifyRejected" />
    <bpmn:sequenceFlow id="Flow_30" sourceRef="Task_NotifyRejected" targetRef="End_Rejected" />
    <bpmn:endEvent id="End_Rejected" name="Fin -Demande rejetée" />
    <bpmn:serviceTask id="Task_NotifyGranted" name="Notifier accès accordé" camunda:type="external" camunda:topic="portal.notifyGranted" />
    <bpmn:sequenceFlow id="Flow_31" sourceRef="Task_NotifyGranted" targetRef="End_Granted" />
    <bpmn:endEvent id="End_Granted" name="Fin - Accès accordé" />
    <bpmn:manualTask id="Task_InstallClient" name="Installer client lourd">
      <bpmn:incoming>Flow_15_client</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="Task_ConfigWorkstation" name="Configurer poste">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_0q3qgef</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_0w8q5tp" sourceRef="Gateway_AppType" targetRef="Task_UpdatePortalRights" />
    <bpmn:sequenceFlow id="Flow_0q3qgef" sourceRef="Task_ConfigWorkstation" targetRef="Task_UpdatePortalRights" />
    <bpmn:inclusiveGateway id="Gateway_HasAccess" name="Accès déjà accordé ?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_no</bpmn:outgoing>
    </bpmn:inclusiveGateway>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Portal_Access">
